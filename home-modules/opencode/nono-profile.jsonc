// nono sandbox profile for OpenCode. Policy source of truth.
// Rationale, design tensions, and the egress allowlist analysis live in
// nono-egress.md and home-modules/opencode/README.md.
{
	"$schema": "https://nono.sh/schemas/nono-profile.schema.json",

	"extends": "default", // inherits 18 default deny groups

	"meta": {
		"name": "opencode",
		"version": "1.0.0",
		"description": "OpenCode AI coding agent sandbox.",
		"author": "nixos-config/home-modules/opencode"
	},

	"groups": {
		"include": [
			"nix_runtime",
			"linux_runtime_state",
			"opencode_linux",
			"user_tools",
			"user_caches_linux",
			"unlink_protection"
		]
	},

	"workdir": {
		"access": "readwrite"
	},

	"filesystem": {
		"allow": [
			"$XDG_DATA_HOME/opencode",
			"$XDG_CONFIG_HOME/opencode",
			"$XDG_CACHE_HOME/opencode",
			"$XDG_STATE_HOME/opencode",
			"$XDG_DATA_HOME/opencode-anthropic-auth", // OAuth token cache (anthropic-auth-sync)
			"$HOME/.claude", // Claude Code OAuth tokens, read by anthropic-auth-sync
			"$HOME/.cache/ck", // ck code-search cache
			"$HOME/.cache",
			"$HOME/.worktrees",
			"$XDG_DATA_HOME/opencode/tmp",
			"/tmp" // Bun OpenTUI .so extraction target — required for the TUI; see README.md
		],

		"read": [
			"$HOME/.config/git",
			"$HOME/.gitconfig",
			"$HOME/.ssh",
			"/run/secrets" // SOPS-materialized API keys
		],

		// 1Password SSH agent socket: deny_credentials blocks it, so bypass + allow.
		"allow_file": ["$HOME/.1password/agent.sock"],
		"bypass_protection": ["$HOME/.1password/agent.sock"]
	},

	// Positive list; vars not set by the wrapper are simply empty in the child.
	"environment": {
		"allow_vars": [
			"PATH",
			"HOME",
			"TERM",
			"USER",
			"SHELL",
			"LANG",
			"LOCALE_ARCHIVE",
			"NIX_CONFIG",
			"NIX_PATH",
			"NIX_PROFILES",
			"SSL_CERT_FILE",
			"COLORTERM",
			"OPENCODE_CONFIG_CONTENT",
			"OPENCODE_EXPERIMENTAL_DISABLE_COPY_ON_SELECT", // disable auto-copy-on-select; see README "Clipboard"
			"WAYLAND_DISPLAY", // wl-clipboard: locate compositor socket (opt-in hosts)
			"XDG_RUNTIME_DIR", // wl-clipboard: socket dir base (opt-in hosts)
			"ZAI_API_KEY",
			"OPENAI_API_KEY",
			"CONTEXT7_API_KEY"
		]
	},

	// Egress allowlist. block:false = proxy on, unlisted domains blocked at the
	// HTTP(S) layer. Per-domain and SSH/webfetch rationale is in nono-egress.md.
	"network": {
		"block": false,

		// Pins the TUI's loopback port; must match --port in the wrapper. See nono-egress.md.
		"open_port": [4099],

		"allow_domain": [
			// ── LLM providers ────────────────────────────────────────────────────
			"api.z.ai", // z.ai GLM-5.x (primary orchestrator via ZAI_API_KEY)
			"api.anthropic.com", // Anthropic API (Claude models via @ex-machina OAuth)
			"claude.ai", // Claude Code Max OAuth login + token refresh
			"opencode.ai", // OpenCode Go provider OAuth login + token refresh
			"api.openai.com", // OpenAI API (Hephaestus + last-resort fallbacks)
			"*.openai.com", // OpenAI CDN / auxiliary endpoints
			"api.opencode.ai", // OpenCode Go inference API (opencode.ai is OAuth/console; api.* serves models)
			"models.dev", // Model catalog / discovery

			// ── Package registries ────────────────────────────────────────────────
			"registry.npmjs.org", // npm package installs (nodejs tooling)
			"*.npmjs.org", // npm CDN / scoped registries
			"github.com", // git clone, GitHub API, releases
			"*.github.com", // GitHub subdomains (gist, etc.)
			"objects.githubusercontent.com", // GitHub release asset downloads (legacy host)
			"release-assets.githubusercontent.com", // GitHub release asset downloads (current CDN host)
			"codeload.github.com", // GitHub archive downloads (go get, etc.)
			"raw.githubusercontent.com", // raw file access (scripts, configs)
			"api.github.com", // GitHub REST API (gh CLI, MCP server)
			"pypi.org", // Python package index
			"*.pypi.org", // PyPI CDN / mirrors
			"files.pythonhosted.org", // PyPI file hosting
			"crates.io", // Rust crate registry
			"static.crates.io", // crates.io static assets
			"*.crates.io", // crates.io CDN
			"api.nuget.org", // NuGet package API
			"*.nuget.org", // NuGet CDN / feeds
			"cache.nixos.org", // Nix binary cache (primary substituter)
			"*.nixos.org", // NixOS infrastructure (search, channels, etc.)
			"search.nixos.org", // NixOS package/option search

			// ── Nix substituters ─────────────────────────────────────────────────
			"cache.numtide.com", // numtide binary cache (devshell, etc.)

			// ── MCP / research tools ──────────────────────────────────────────────
			"api.exa.ai", // Exa web search MCP tool
			"grep.app", // grep.app code search MCP tool
			"context7.com", // Context7 documentation MCP tool
			"*.context7.com" // Context7 CDN / API subdomains
		]
	},

	// Origins nono may open in the host browser for OAuth login. See README.md.
	"open_urls": {
		"allow_origins": [
			"https://claude.ai",
			"https://opencode.ai",
			"https://console.anthropic.com"
		],
		"allow_localhost": false
	}
}
