{
  "mcpServers": {
    "nixos": {
      "command": "mcp-nixos"
    },
    "adrs": {
      "command": "adrs",
      "args": ["mcp", "serve"]
    },
    "context7": {
      "command": "context7-with-sops",
      "enabled": false
    },
    "github-personal": {
      "command": "github-personal-mcp",
      "enabled": false
    },
    "playwright": {
      "command": "mcp-server-playwright",
      "enabled": false
    }
  }
}
